{
  "name": "galaxy-workflows",
  "packageManager": "pnpm@10.33.0",
  "displayName": "Galaxy Workflows",
  "description": "Utilities to assist in the edition of Galaxy (https://galaxyproject.org/) Workflow files.",
  "version": "0.5.0",
  "preview": true,
  "license": "MIT",
  "publisher": "davelopez",
  "maintainers": [
    {
      "name": "Simon Bray",
      "url": "https://github.com/simonbray"
    },
    {
      "name": "Wolfgang Maier",
      "url": "https://github.com/wm75"
    },
    {
      "name": "David López",
      "url": "https://github.com/davelopez"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/davelopez/galaxy-workflows-vscode"
  },
  "bugs": {
    "url": "https://github.com/davelopez/galaxy-workflows-vscode/issues"
  },
  "icon": "assets/galaxy-logo-icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Linters",
    "Snippets",
    "Formatters",
    "Other"
  ],
  "main": "./client/dist/extension",
  "browser": "./client/dist/web/extension",
  "contributes": {
    "languages": [
      {
        "id": "galaxyworkflow",
        "aliases": [
          "Galaxy Workflow (JSON)"
        ],
        "extensions": [
          ".ga"
        ],
        "configuration": "./workflow-languages/configurations/json.language-configuration.json"
      },
      {
        "id": "gxformat2",
        "aliases": [
          "Galaxy Workflow (YAML)"
        ],
        "extensions": [
          ".gxwf.yml",
          ".gxwf.yaml"
        ],
        "configuration": "./workflow-languages/configurations/yml.language-configuration.json"
      },
      {
        "id": "gxwftests",
        "aliases": [
          "Galaxy Workflow Tests (YAML)"
        ],
        "extensions": [
          "-test.yml",
          "-tests.yml",
          "-test.yaml",
          "-tests.yaml"
        ],
        "configuration": "./workflow-languages/configurations/yml.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "galaxyworkflow",
        "scopeName": "source.ga",
        "path": "./workflow-languages/syntaxes/json.tmLanguage.json"
      },
      {
        "language": "gxformat2",
        "scopeName": "source.gxformat2",
        "path": "./workflow-languages/syntaxes/yml.tmLanguage.json"
      },
      {
        "language": "gxwftests",
        "scopeName": "source.gxformat2",
        "path": "./workflow-languages/syntaxes/yml.tmLanguage.json"
      }
    ],
    "configuration": [
      {
        "title": "Galaxy Workflows",
        "properties": {
          "galaxyWorkflows.validation.profile": {
            "markdownDescription": "The set of rules that will be used to validate workflow documents.",
            "scope": "resource",
            "type": "string",
            "enum": [
              "basic",
              "iwc"
            ],
            "markdownEnumDescriptions": [
              "Basic validation based on the Galaxy workflow schema.",
              "Stricter validation to comply with the `Intergalactic Workflow Commission` best practices."
            ],
            "default": "basic"
          },
          "galaxyWorkflows.toolCache.directory": {
            "markdownDescription": "Directory containing cached tool definitions (shared with `galaxy-tool-cache` CLI).",
            "scope": "machine",
            "type": "string",
            "default": "~/.galaxy/tool_info_cache"
          },
          "galaxyWorkflows.toolShed.url": {
            "markdownDescription": "ToolShed URL used to fetch tool definitions on cache miss.",
            "scope": "machine",
            "type": "string",
            "default": "https://toolshed.g2.bx.psu.edu"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "galaxy-workflows.previewCleanWorkflow",
        "title": "Preview clean workflow",
        "enablement": "resourceLangId == galaxyworkflow",
        "icon": "$(eye)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.cleanWorkflow",
        "title": "Clean workflow",
        "enablement": "resourceLangId == galaxyworkflow",
        "icon": "$(edit)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.selectForCleanCompare",
        "title": "Select workflow for (clean) compare",
        "enablement": "resourceLangId == galaxyworkflow",
        "icon": "$(diff)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.compareCleanWith",
        "title": "Compare with this workflow (clean)",
        "enablement": "resourceLangId == galaxyworkflow",
        "icon": "$(diff)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.populateToolCache",
        "title": "Populate Tool Cache",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.populateToolCacheForTool",
        "title": "Populate Tool Cache (single tool)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.previewConvertToFormat2",
        "title": "Preview Convert to Format2",
        "enablement": "resourceLangId == galaxyworkflow",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.previewConvertToNative",
        "title": "Preview Convert to Native (.ga)",
        "enablement": "resourceLangId == gxformat2",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.exportToFormat2",
        "title": "Export as Format2 (.gxwf.yml)",
        "enablement": "resourceLangId == galaxyworkflow",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.exportToNative",
        "title": "Export as Native (.ga)",
        "enablement": "resourceLangId == gxformat2",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.convertFileToFormat2",
        "title": "Convert File to Format2",
        "enablement": "resourceLangId == galaxyworkflow",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.convertFileToNative",
        "title": "Convert File to Native (.ga)",
        "enablement": "resourceLangId == gxformat2",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.refreshToolsView",
        "title": "Refresh Workflow Tools",
        "icon": "$(refresh)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.revealToolStep",
        "title": "Reveal step in workflow",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.openToolInToolShed",
        "title": "Open tool in ToolShed",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.insertToolStep",
        "title": "Insert Tool Step…",
        "enablement": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2",
        "icon": "$(add)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.previewMermaidDiagram",
        "title": "Preview Diagram (Mermaid)",
        "enablement": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2",
        "icon": "$(graph)",
        "category": "Galaxy Workflows"
      },
      {
        "command": "galaxy-workflows.exportMermaid",
        "title": "Export as Mermaid (.mmd)",
        "enablement": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2",
        "category": "Galaxy Workflows"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "galaxyWorkflows.toolsView",
          "name": "Workflow Tools",
          "when": "resourceExtname == .ga || resourceExtname == .yml || resourceExtname == .yaml"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "galaxyWorkflows.toolsView",
        "contents": "Open a Galaxy workflow (.ga or .gxwf.yml) to see its tools."
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "galaxy-workflows.previewCleanWorkflow",
          "when": "activeEditor"
        },
        {
          "command": "galaxy-workflows.cleanWorkflow",
          "when": "activeEditor"
        },
        {
          "command": "galaxy-workflows.selectForCleanCompare",
          "when": "false"
        },
        {
          "command": "galaxy-workflows.compareCleanWith",
          "when": "false"
        },
        {
          "command": "galaxy-workflows.previewConvertToFormat2",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.previewConvertToNative",
          "when": "resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.exportToFormat2",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.exportToNative",
          "when": "resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.convertFileToFormat2",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.convertFileToNative",
          "when": "resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.populateToolCacheForTool",
          "when": "false"
        },
        {
          "command": "galaxy-workflows.insertToolStep",
          "when": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.previewMermaidDiagram",
          "when": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.exportMermaid",
          "when": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2"
        }
      ],
      "timeline/item/context": [
        {
          "command": "galaxy-workflows.compareCleanWith",
          "group": "3_compare@1",
          "when": "false && config.git.enabled && !git.missing && galaxy-workflows.selectForCleanCompare"
        },
        {
          "command": "galaxy-workflows.selectForCleanCompare",
          "group": "3_compare@2",
          "when": "false && config.git.enabled && !git.missing && timelineItem =~ /git:file\\b/ && galaxy-workflows.gitProviderInitialized"
        }
      ],
      "explorer/context": [
        {
          "command": "galaxy-workflows.compareCleanWith",
          "group": "3_compare@1",
          "when": "config.git.enabled && !git.missing && galaxy-workflows.selectForCleanCompare"
        },
        {
          "command": "galaxy-workflows.selectForCleanCompare",
          "group": "3_compare@2",
          "when": "config.git.enabled && !git.missing && galaxy-workflows.gitProviderInitialized"
        }
      ],
      "editor/context": [
        {
          "command": "galaxy-workflows.previewCleanWorkflow",
          "group": "galaxyworkflow@1",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.cleanWorkflow",
          "group": "galaxyworkflow@2",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.previewConvertToFormat2",
          "group": "galaxyworkflow@3",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.previewConvertToNative",
          "group": "galaxyworkflow@3",
          "when": "resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.exportToFormat2",
          "group": "galaxyworkflow@4",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.exportToNative",
          "group": "galaxyworkflow@4",
          "when": "resourceLangId == gxformat2"
        },
        {
          "command": "galaxy-workflows.convertFileToFormat2",
          "group": "galaxyworkflow@5",
          "when": "resourceLangId == galaxyworkflow"
        },
        {
          "command": "galaxy-workflows.convertFileToNative",
          "group": "galaxyworkflow@5",
          "when": "resourceLangId == gxformat2"
        }
      ],
      "editor/title": [
        {
          "command": "galaxy-workflows.previewMermaidDiagram",
          "when": "resourceLangId == galaxyworkflow || resourceLangId == gxformat2",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "galaxy-workflows.refreshToolsView",
          "when": "view == galaxyWorkflows.toolsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "galaxy-workflows.revealToolStep",
          "when": "view == galaxyWorkflows.toolsView && viewItem == workflowTool",
          "group": "inline@1"
        },
        {
          "command": "galaxy-workflows.openToolInToolShed",
          "when": "view == galaxyWorkflows.toolsView && viewItem == workflowTool",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint ./client/src ./server --ext .ts,.tsx",
    "format": "prettier --write .",
    "clean": "rimraf client/dist && rimraf client/out && pnpm --dir server run clean",
    "compile-client": "cd client && tsup",
    "compile-servers": "pnpm --dir server run compile",
    "compile": "pnpm run clean && pnpm run compile-client && pnpm run compile-servers",
    "vscode:prepublish": "pnpm run compile",
    "watch": "concurrently --kill-others \"pnpm run watch-server\" \"pnpm run watch-client\"",
    "watch-server": "pnpm --dir server run watch",
    "watch-client": "cd client && tsup --watch",
    "test": "pnpm run test-client && pnpm run test-server",
    "test-client": "pnpm --dir client test",
    "test-server": "pnpm --dir server test",
    "test-compile": "tsc --project ./client/tests/e2e --outDir client/out/tests/e2e",
    "pretest:e2e": "pnpm run clean && pnpm run compile && pnpm run test-compile",
    "test:e2e": "node ./client/out/tests/e2e/runTests.js",
    "test-browser": "vscode-test-web --extensionDevelopmentPath=. ./test-data"
  },
  "devDependencies": {
    "@swc/core": "^1.4.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.8",
    "@types/mocha": "^10.0.1",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "@vscode/test-electron": "^2.3.4",
    "@vscode/test-web": "^0.0.80",
    "assert": "^2.0.0",
    "concurrently": "^8.2.1",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.4",
    "jest-transform-yaml": "^1.1.2",
    "mocha": "^10.2.0",
    "prettier": "3.0.3",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.2.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2",
    "yaml": "^2.3.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.12",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@playwright/browser-chromium",
      "@swc/core",
      "esbuild"
    ],
    "overrides": {
      "@galaxy-tool-util/core": "1.1.0",
      "@galaxy-tool-util/schema": "1.1.0",
      "@galaxy-tool-util/search": "1.1.0"
    }
  },
  "__metadata": {
    "id": "2306ad21-fa2c-46f9-bba8-a22e32c7cb9a",
    "publisherDisplayName": "davelopez",
    "publisherId": "b10132ef-3f96-4db4-acb0-d6a0ca1848c7",
    "isPreReleaseVersion": false
  }
}
