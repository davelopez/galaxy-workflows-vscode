{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["ES2019", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test-web"]
}
